# ── Server ───────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# ── MongoDB ──────────────────────────────────────────────────────────────
# Local:  mongodb://localhost:27017/syncwave
# Docker: mongodb://mongo:27017/syncwave  (set automatically by docker-compose)
# Atlas:  mongodb+srv://<user>:<password>@<cluster>.mongodb.net/syncwave
MONGO_URI=mongodb://localhost:27017/syncwave

# ── Redis (BullMQ queues, Socket.io presence) ───────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ── JWT ──────────────────────────────────────────────────────────────────
# Generate strong secrets with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ── Cloudinary (avatars, song covers, audio uploads) ────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Google OAuth ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/v1/auth/google/callback

# ── Spotify OAuth ────────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_CALLBACK_URL=http://localhost:5000/api/v1/auth/spotify/callback

# ── SMTP (Nodemailer) — leave blank in dev; emails log to console/queue ─
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=SyncWave <no-reply@syncwave.app>

# ── Security ─────────────────────────────────────────────────────────────
BCRYPT_SALT_ROUNDS=10
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
